SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:5432/postgres
CHANNEL_HMAC_SECRET=generate-a-long-random-string
CRM_RECEIPTS_URL=http://localhost:8000/api/v1/receipts
CHANNEL_SEND_URL=http://localhost:8001/send
JITTER_MIN_SECONDS=0.5
JITTER_MAX_SECONDS=30
DUPLICATE_PROBABILITY=0.1
REORDER_PROBABILITY=0.15
GROQ_API_KEY=your-groq-key
OPENROUTER_API_KEY=your-openrouter-key
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Comma-separated allowed browser origins for the crm_api. Local dev default below;
# in prod set this to your Vercel URL, e.g. https://lumen-frontend.vercel.app
CORS_ORIGINS=http://localhost:3000
